<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?android:attr/selectableItemBackground"
    android:padding="12dp"
    android:layout_marginVertical="2dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <!-- Amount and Bank -->
    <TextView
        android:id="@+id/tv_amount_bank"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="₹276 • HDFC Bank"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="4dp" />

    <!-- Date and Confidence -->
    <TextView
        android:id="@+id/tv_date_confidence"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1 hour ago • 98% confidence"
        android:textSize="12sp"
        android:textColor="@color/text_secondary" />

    <!-- Tags (populated only when the transaction has tags) -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_item_tags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:visibility="gone"
        app:chipSpacingHorizontal="4dp"
        app:chipSpacingVertical="2dp"
        app:singleLine="false" />

</LinearLayout>